# Google AI Studio
GOOGLE_API_KEY=your-api-key-here
GOOGLE_CHAT_MODEL=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI
OPENAI_API_KEY=your-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ChromaDB
CHROMA_DB_PATH=./data/chroma_db

# Data
DATA_DIR=./data

# RAG
TITLE_WEIGHT=0.5
CONTENT_WEIGHT=0.5
TOP_K=5

# Hybrid Search (BM25 키워드 + 벡터 RRF 융합) — false면 순수 벡터 검색
HYBRID_ENABLED=true
RRF_K=60
KEYWORD_TOP_N=20

# 위키 수집 (scripts/sync_manual.py --source crawl) — api-spec.md 섹션 9
# 회사 PC에서만 필요. 쿠키는 브라우저 개발자도구 → Network → Cookie 헤더 복사
WIKI_BASE_URL=https://wiki.hanwhawm.com
WIKI_COOKIE=JSESSIONID=...
WIKI_SPACE_KEYS=BM001
# URL 템플릿 — 실제 화면 URL에 맞게 수정 ({base}, {space} 자동 치환)
# 실측: 목록 화면은 /collector/ 하위, 본문(viewpage.action)은 루트 하위
WIKI_PAGE_LIST_URL={base}/collector/pages.action?key={space}
WIKI_RECENT_URL={base}/pages/recentlyupdated.action?key={space}
WIKI_CRAWL_DELAY=0.5
META_DB_PATH=./data/meta.db